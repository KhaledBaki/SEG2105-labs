<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/TeamName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Team Name"
        android:inputType="text"
        tools:layout_editor_absoluteX="100dp"
        tools:layout_editor_absoluteY="320dp" />

    <EditText
        android:id="@+id/TeamPostalCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Team Postal Code"
        android:inputType="text"
        tools:layout_editor_absoluteX="100dp"
        tools:layout_editor_absoluteY="374dp" />


    <ImageView
        android:id="@+id/QuestionMarkLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="setLogo"
        app:srcCompat="@drawable/ic_logo_00"
        tools:layout_editor_absoluteX="143dp"
        tools:layout_editor_absoluteY="159dp" />

    <TextView
        android:id="@+id/MainTitle"
        android:layout_width="154dp"
        android:layout_height="20dp"
        android:text="Soccer Team Manager"
        android:textAlignment="center"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.41" />

    <Button
        android:id="@+id/SubmitButton"
        android:backgroundTint="#00BF00"
        android:layout_width="234dp"
        android:layout_height="46dp"
        android:onClick="submit"
        android:text="Submit"
        tools:layout_editor_absoluteX="88dp"
        tools:layout_editor_absoluteY="487dp" />

    <Button
        android:id="@+id/GoogleMapsButton"
        android:backgroundTint="#0000FF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="openInGoogleMaps"
        android:text="Open in Google Maps"
        tools:layout_editor_absoluteX="113dp"
        tools:layout_editor_absoluteY="426dp" />

</androidx.constraintlayout.widget.ConstraintLayout>